# ========== 模式控制 ==========
# stable: 可控模式（停用所有自治，單一執行路徑）預設
# full:   完整自治模式（含自我進化/學習/修復）
OBSIDIAN_MODE=stable

# ========== Telegram Bot ==========
TELEGRAM_TOKEN_OBSIDIAN=your_telegram_bot_token_here
AUTHORIZED_USER_IDS=your_user_id_here

# ========== LLM API (至少需要一個) ==========
# DeepSeek
# DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-v4-pro

# NVIDIA
# NVIDIA_API_KEY=nvapi-xxx

# Alibaba
# ALIBABA_API_KEY=sk-xxx

# HuggingFace
# HUGGINGFACE_TOKEN=hf_xxx

# ATXP (LLM Gateway + Payment)
# ATXP_CONNECTION_STRING=https://accounts.atxp.ai?connection_token=xxx
# ATXP_MODEL=gpt-4.1

# Cloudflare
# CLOUDFLARE_API_TOKEN=cfut_xxx
# CLOUDFLARE_GLOBAL_KEY=xxx

# ========== Ollama 本機 (若使用請設定) ==========
OLLAMA_MODEL=qwen2.5:7b
