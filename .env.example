# ========== 模式控制 ==========
OBSIDIAN_MODE=full

# ========== Telegram Bot ==========
TELEGRAM_TOKEN_OBSIDIAN=你的黑曜主BotToken
TELEGRAM_TOKEN_SERVICE=你的售後服務BotToken
AUTHORIZED_USER_IDS=你的Telegram用戶ID（逗號分隔）

# ========== LLM API ==========
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
NVIDIA_API_KEY=nvapi-your-nvidia-key
ALIBABA_API_KEY=sk-your-alibaba-key
HUGGINGFACE_TOKEN=hf_your-token

# ========== OpenRouter (備援) ==========
OPENROUTER_API_KEY=sk-or-your-key
TOGETHER_API_KEY=tgp_v1_your-key

# ========== Ollama 本機 ==========
OLLAMA_MODEL=qwen2.5:7b
DEFAULT_MODEL=DeepSeek

# ========== ATXP/Circuit 支付 + LLM Gateway ==========
ATXP_CONNECTION_STRING=https://accounts.atxp.ai?connection_token=xxx&account_id=xxx
ATXP_ACCOUNT_ID=atxp_acct_xxx
ATXP_CONNECTION_TOKEN=xxx
ATXP_MODEL=gpt-4.1

# ========== Cloudflare ==========
CLOUDFLARE_API_TOKEN=cfut_xxx
CLOUDFLARE_API_TOKEN_2=cfut_xxx
CLOUDFLARE_GLOBAL_KEY=xxx

# ========== GitHub ==========
GITHUB_API_KEY=github_pat_xxx

# ========== BscScan（USDT 自動對帳）==========
# 申請：https://bscscan.com → API Keys → 建立 Key
BSCSCAN_API_KEY=YourBscScanApiKeyHere

# ========== 平台上架憑證（Readmoo mooPub / Amazon KDP）==========
# Readmoo mooPub: 用你的 Readmoo 帳號登入 https://moopub.readmoo.com
READMOO_EMAIL=your-readmoo-email@example.com
READMOO_PASSWORD=your-readmoo-password
# Amazon KDP: 用你的 Amazon 出版帳號登入 https://kdp.amazon.com
KDP_EMAIL=your-kdp-email@example.com
KDP_PASSWORD=your-kdp-password
