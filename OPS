def scan_directory_tree(base_dir=None, max_depth=5):
    if base_dir is None:
        base_dir = PROJECT_ROOT
    report = {"total_dirs": 0, "total_files": 0, "total_size_bytes": 0, "json_files": [], "py_files": [], "dirs": [], "missing_expected": []}
    expected_dirs = ["data/state", "data/circuit", "data/compass", "data/tasks", "memory", "tools/registry", "agents", "logs", "src", "src/brain", "src/blood", "src/circuit", "src/compass", "src/core", "src/immune", "src/muscle", "src/nerve", "src/skeleton", "src/skin", "src/tasks", "src/waste", "src/web", "src/womb", "dashboard", "tools"]
    for rel_path in expected_dirs:
        full_path = base_dir / rel_path
        if not full_path.exists():
            report["missing_expected"].append(rel_path)
    try:
        for root, dirs, files in os.walk(str(base_dir)):
            root_path = Path(root)
            dirs[:] = [d for d in dirs if not d.startswith('.') and d not in EXCLUDE_DIRS]
            rel_root = root_path.relative_to(base_dir)
            depth = len(rel_root.parts)
            if depth > max_depth:
                dirs.clear()
                continue
            report["total_dirs"] += len(dirs)
            report["total_files"] += len(files)
            for f in files:
                file_path = root_path / f
                try:
                    report["total_size_bytes"] += file_path.stat().st_size
                except:
                    pass
                if f.endswith('.json'):
                    report["json_files"].append(str(rel_root / f))
                elif f.endswith('.py'):
                    report["py_files"].append(str(rel_root / f))
            report["dirs"].append(str(rel_root))
    except Exception as e:
        print(f"掃描目錄時發生錯誤: {e}")
    return report

def find_duplicates(base_dir=None):
    if base_dir is None:
        base_dir = PROJECT_ROOT
    base_path = Path(base_dir)
    hash_map = {}
    duplicates = []
    for root, dirs, files in os.walk(str(base_path)):
        dirs[:] = [d for d in dirs if d not in EXCLUDE_DIRS]
        for f in files:
            file_path = Path(root) / f
            try:
                with open(file_path, "rb") as fp:
                    file_hash = hashlib.md5(fp.read()).hexdigest()
                if file_hash in hash_map:
                    hash_map[file_hash].append(str(file_path))
                else:
                    hash_map[file_hash] = [str(file_path)]
            except Exception:
                pass
    for file_hash, paths in hash_map.items():
        if len(paths) > 1:
            duplicates.append({"hash": file_hash, "paths": paths, "count": len(paths)})
    return duplicates

def find_backups(base_dir=None):
    if base_dir is None:
        base_dir = PROJECT_ROOT
    base_path = Path(base_dir)
    backup_patterns = ["backup", "bak", "old", "archive", "copy", "_v1", "_v2", "_old", "_backup", ".bak", ".old", ".backup"]
    backups = []
    for root, dirs, files in os.walk(str(base_path)):
        dirs[:] = [d for d in dirs if d not in EXCLUDE_DIRS]
        root_path = Path(root)
        for f in files:
            file_path = root_path / f
            rel_path = file_path.relative_to(base_path)
            lower_name = f.lower()
            is_backup = any(pattern in lower_name for pattern in backup_patterns)
            if "versions" in rel_path.parts:
                is_backup = True
            if is_backup:
                backups.append(str(rel_path))
    return backups

def cleanup_duplicates(base_dir=None, dry_run=True):
    if base_dir is None:
        base_dir = PROJECT_ROOT
    base_path = Path(base_dir)
    print("=" * 60)
    print("  清理重複與備份檔案")
    print("=" * 60)
    print("\n🔍 掃描重複檔案中...")
    duplicates = find_duplicates(base_path)
    if duplicates:
        print(f"\n📋 找到 {len(duplicates)} 組重複檔案:")
        total_duplicate_files = sum(d["count"] - 1 for d in duplicates)
        print(f"   總共可刪除 {total_duplicate_files} 個重複檔案")
        for dup in duplicates[:10]:
            print(f"\n   🔗 重複組 (MD5: {dup['hash'][:8]}...):")
            for path in dup["paths"]:
                rel = Path(path).relative_to(base_path)
                print(f"      • {rel}")
            if len(dup["paths"]) > 3:
                print(f"      ... 還有 {len(dup['paths']) - 3} 個")
        if len(duplicates) > 10:
            print(f"\n   ... 還有 {len(duplicates) - 10} 組未顯示")
    else:
        print("   ✅ 未發現重複檔案")
    print("\n🔍 掃描備份檔案中...")
    backups = find_backups(base_path)
    if backups:
        print(f"\n📋 找到 {len(backups)} 個備份檔案:")
        for b in backups[:20]:
            print(f"      • {b}")
        if len(backups) > 20:
            print(f"      ... 還有 {len(backups) - 20} 個")
    else:
        print("   ✅ 未發現備份檔案")
    print("\n🔍 掃描 __pycache__ 目錄中...")
    pycache_dirs = []
    for root, dirs, files in os.walk(str(base_path)):
        dirs[:] = [d for d in dirs if d not in EXCLUDE_DIRS]
        if "__pycache__" in dirs:
            pycache_dirs.append(Path(root) / "__pycache__")
    if pycache_dirs:
        print(f"\n📋 找到 {len(pycache_dirs)} 個 __pycache__ 目錄:")
        for d in pycache_dirs[:10]:
            rel = d.relative_to(base_path)
            print(f"      • {rel}")
        if len(pycache_dirs) > 10:
            print(f"      ... 還有 {len(pycache_dirs) - 10} 個")
    else:
        print("   ✅ 未發現 __pycache__ 目錄")
    if not dry_run:
        print("\n\n🗑️  開始清理...")
        deleted_count = 0
        for dup in duplicates:
            for path in dup["paths"][1:]:
                try:
                    Path(path).unlink()
                    deleted_count += 1
                except Exception as e:
                    print(f"   ❌ 無法刪除 {path}: {e}")
        for b in backups:
            try:
                (base_path / b).unlink()
                deleted_count += 1
            except Exception as e:
                print(f"   ❌ 無法刪除 {b}: {e}")
        import shutil
        for d in pycache_dirs:
            try:
                shutil.rmtree(str(d))
                deleted_count += 1
            except Exception as e:
                print(f"   ❌ 無法刪除 {d}: {e}")
        print(f"\n✅ 已刪除 {deleted_count} 個項目")
    else:
        print(f"\n💡 若要實際執行清理，請加上 --apply 參數")
        print(f"    python OPS cleanup --apply")
    print("\n" + "=" * 60)

def organize_files(base_dir=None, dry_run=True):
    if base_dir is None:
        base_dir = PROJECT_ROOT
    base_path = Path(base_dir)
    categories = {"python": [".py"], "json": [".json"], "markdown": [".md", ".markdown"], "text": [".txt", ".log", ".cfg", ".ini", ".conf"], "env": [".env", ".env.example"], "yaml": [".yaml", ".yml"], "html": [".html", ".htm"], "css": [".css"], "js": [".js"], "shell": [".sh", ".bash", ".zsh"], "docker": ["Dockerfile", "docker-compose.yml", "docker-compose.yaml"], "git": [".gitignore", ".gitattributes"], "license": ["LICENSE", "LICENSE.txt", "LICENSE.md"], "readme": ["README.md", "README.txt", "README"], "requirements": ["requirements.txt", "requirements-dev.txt"], "makefile": ["Makefile", "makefile"], "other": []}
    organized_dir = base_path / "organized"
    if not dry_run:
        organized_dir.mkdir(exist_ok=True)
    moved_files = []
    skipped_files = []
    errors = []
    for root, dirs, files in os.walk(str(base_path)):
        dirs[:] = [d for d in dirs if d not in EXCLUDE_DIRS]
        root_path = Path(root)
        for f in files:
            file_path = root_path / f
            rel_path = file_path.relative_to(base_path)
            category = "other"
            for cat_name, extensions in categories.items():
                if any(f.endswith(ext) for ext in extensions):
                    category = cat_name
                    break
                if f in extensions:
                    category = cat_name
                    break
            dest = organized_dir / category / rel_path
            dest.parent.mkdir(parents=True, exist_ok=True)
            if dry_run:
                moved_files.append((str(rel_path), str(dest)))
            else:
                try:
                    if dest.exists():
                        timestamp = int(time.time())
                        dest = dest.with_name(f"{dest.stem}_{timestamp}{dest.suffix}")
                    file_path.rename(dest)
                    moved_files.append((str(rel_path), str(dest)))
                except Exception as e:
                    errors.append((str(rel_path), str(e)))
    print("=" * 60)
    print("  檔案整理報告")
    print("=" * 60)
    if dry_run:
        print(f"\n🔍 模擬執行（未實際移動檔案）")
    else:
        print(f"\n✅ 已執行檔案移動")
    print(f"\n📊 統計:")
    print(f"  總檔案數: {len(moved_files) + len(skipped_files)}")
    print(f"  將移動: {len(moved_files)}")
    print(f"  跳過: {len(skipped_files)}")
    if errors:
        print(f"  錯誤: {len(errors)}")
    cat_counts = Counter()
    for src, dst in moved_files:
        parts = Path(dst).relative_to(organized_dir).parts
        if parts:
            cat_counts[parts[0]] += 1
    print(f"\n📁 分類統計:")
    for cat, count in sorted(cat_counts.items(), key=lambda x: -x[1]):
        print(f"  {cat}: {count} 個檔案")
    if dry_run:
        print(f"\n💡 若要實際執行，請加上 --apply 參數")
        print(f"    python OPS organize --apply")
    if errors:
        print(f"\n❌ 錯誤:")
        for path, err in errors[:10]:
            print(f"  {path}: {err}")
        if len(errors) > 10:
            print(f"  ... 還有 {len(errors) - 10} 個錯誤")
    print("=" * 60)
    return moved_files, errors

def print_status_report(base_dir=None, deep=False):
    if base_dir is None:
        base_dir = PROJECT_ROOT
    print("=" * 60)
    print("  黑曜系統狀態報告")
    print("=" * 60)
    print("\n📋 執行中實例:")
    instances = check_instances(base_dir)
    if instances:
        for inst in instances:
            if "pid" in inst:
                print(f"  PID: {inst['pid']} | CPU: {inst.get('cpu','?')}% | MEM: {inst.get('mem','?')}% | {inst.get('command','?')[:60]}")
            else:
                print(f"  心跳: {inst.get('time','?')} | PID: {inst.get('pid','?')} | 狀態: {inst.get('status','?')}")
    else:
        print("  未發現執行中實例")
    print("\n📁 目錄結構:")
    required_dirs = [Path(base_dir) / "memory", Path(base_dir) / "tools" / "registry", Path(base_dir) / "agents", Path(base_dir) / "data" / "state", Path(base_dir) / "logs"]
    for d in required_dirs:
        if d.exists():
            print(f"  ✅ {d}")
        else:
            print(f"  ❌ {d} (缺失)")
    if deep:
        print("\n🔍 深度掃描:")
        scan = scan_directory_tree(Path(base_dir))
        print(f"  總目錄數: {scan['total_dirs']}")
        print(f"  總檔案數: {scan['total_files']}")
        print(f"  總大小: {scan['total_size_bytes'] / 1024:.1f} KB")
        print(f"  JSON 檔案數: {len(scan['json_files'])}")
        print(f"  Python 檔案數: {len(scan['py_files'])}")
        if scan["missing_expected"]:
            print(f"\n  ⚠️  缺少的預期目錄 ({len(scan['missing_expected'])}):")
            for d in scan["missing_expected"]:
                print(f"    ❌ {d}")
        if scan["json_files"]:
            print(f"\n  📄 JSON 檔案:")
            for f in scan["json_files"][:20]:
                print(f"    • {f}")
            if len(scan["json_files"]) > 20:
                print(f"    ... 還有 {len(scan['json_files']) - 20} 個")
        if scan["py_files"]:
            print(f"\n  🐍 Python 檔案:")
            for f in scan["py_files"][:20]:
                print(f"    • {f}")
            if len(scan["py_files"]) > 20:
                print(f"    ... 還有 {len(scan['py_files']) - 20} 個")
    print("\n💻 系統資源:")
    try:
        import psutil
        print(f"  CPU: {psutil.cpu_percent()}%")
        print(f"  記憶體: {psutil.virtual_memory().percent}%")
        print(f"  磁碟: {psutil.disk_usage(str(Path(base_dir))).percent}%")
    except ImportError:
        print("  (需要安裝 psutil)")
    print("\n" + "=" * 60)

def show_help():
    print("黑曜系統操作工具 (OPS)")
    print()
    print("用法: python OPS [命令] [參數]")
    print()
    print("命令:")
    print("  status      檢查系統狀態")
    print("  deep        深度掃描 (等同 status --deep)")
    print("  scan        掃描目錄樹")
    print("  instances   查看執行中實例")
    print("  organize    整理檔案結構")
    print("  cleanup     清理重複與備份檔案")
    print("  help        顯示此說明")
    print()
    print("範例:")
    print("  python OPS status")
    print("  python OPS cleanup")
    print("  python OPS cleanup --apply")
    print("  python OPS organize")
    print("  python OPS organize --apply")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        show_help()
        sys.exit(0)
    command = sys.argv[1]
    args = sys.argv[2:]
    if command == "status":
        deep = "--deep" in args
        print_status_report(deep=deep)
    elif command == "deep":
        print_status_report(deep=True)
    elif command == "scan":
        scan = scan_directory_tree()
        print(json.dumps(scan, ensure_ascii=False, indent=2, default=str))
    elif command == "instances":
        instances = check_instances()
        print(json.dumps(instances, ensure_ascii=False, indent=2))
    elif command == "organize":
        dry_run = "--apply" not in args
        organize_files(dry_run=dry_run)
    elif command == "cleanup":
        dry_run = "--apply" not in args
        cleanup_duplicates(dry_run=dry_run)
    elif command in ("help", "--help", "-h"):
        show_help()
    else:
        print(f"未知命令: {command}")
        print()
        show_help()
        sys.exit(1)
