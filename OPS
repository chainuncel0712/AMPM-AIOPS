#!/usr/bin/env python3
import os, sys, time, json, hashlib, subprocess
from pathlib import Path
from collections import Counter

def _find_project_root():
    current = Path(__file__).resolve().parent
    for _ in range(10):
        if (current / "src" / "monitor.py").exists() or (current / "main.py").exists():
            return current
        current = current.parent
    return Path.cwd()

PROJECT_ROOT = _find_project_root()
os.chdir(str(PROJECT_ROOT))
EXCLUDE_DIRS = {"venv", "organized", "versions", "__pycache__", "node_modules"}

def check_instances(base_dir=None):
    if base_dir is None:
        base_dir = PROJECT_ROOT
    instances = []
    try:
        result = subprocess.run(["ps", "aux"], capture_output=True, text=True)
        lines = result.stdout.split(chr(10))
        for line in lines:
            if "python" in line.lower() and "brain" in line.lower():
                parts = line.split()
                if len(parts) >= 11:
                    instances.append({"pid": parts[1], "cpu": parts[2], "mem": parts[3], "command": " ".join(parts[10:]), "user": parts[0]})
    except Exception as e:
        print(f"無法檢查行程: {e}")
    heartbeat_file = Path(base_dir) / "data" / "state" / "heartbeat.json"
    if heartbeat_file.exists():
        try:
            data = json.loads(heartbeat_file.read_text())
            instances.append({"type": "heartbeat", "time": data.get("time", "?"), "pid": data.get("pid", "?"), "status": data.get("status", "?")})
        except:
            pass
    return instances
